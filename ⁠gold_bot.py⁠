async def analyze_and_trade():
    api = MetaApi(METAAPI_TOKEN)
    try:
        print("🔄 Inajifungua na kuunganisha kwenye akaunti ya Exness...")
        account = await api.metatrader_account_api.get_account(ACCOUNT_ID)
        connection = account.get_rpc_connection()
        await connection.connect()
        await connection.wait_synchronized()
        
        print("✅ Uunganishaji umefanikiwa! Robot ya SMC ipo LIVE kwenye Cloud sasa.")
        is_trading = False

        while True:
            try:
                candles = await connection.get_candles(SYMBOL, 'm5', 5)
                if len(candles) < 3:
                    await asyncio.sleep(10)
                    continue
                
                c1, c2, c3 = candles[-3], candles[-2], candles[-1]
                info = await connection.get_account_information()
                print(f"🕒 [{datetime.datetime.now().strftime('%H:%M:%S')}] Equity: ${info['equity']} | Inasubiri setup...")

                # SMC FVG Logic
                if c1['low'] > c3['high'] and not is_trading:
                    print("🚨 SMC BEARISH FVG! Inatuma order ya SELL...")
                    await connection.create_market_sell_order(SYMBOL, LOT_SIZE)
                    is_trading = True
                elif c1['high'] < c3['low'] and not is_trading:
                    print("🚨 SMC BULLISH FVG! Inatuma order ya BUY...")
                    await connection.create_market_buy_order(SYMBOL, LOT_SIZE)
                    is_trading = True
                else:
                    if is_trading:
                        positions = await connection.get_positions()
                        if not any(p['symbol'] == SYMBOL for p in positions):
                            is_trading = False

                await asyncio.sleep(15)
            except Exception as le:
                print(f"⚠️ Hitilafu ndogo soko likisoma: {str(le)}")
                await asyncio.sleep(5)
    except Exception as e:
        print(f"❌ Kushindwa kuwasha kabisa kwenye Cloud: {str(e)}")
    finally:
        try:
            await api.close()
        except:
            pass

if __name__ == "__main__":
    asyncio.run(analyze_and_trade())
